# Copy to .env and fill in real values. Keep this file in sync with the env
# schema (src/config/env.schema.mjs) — `npm run check:env-example` enforces it.

# --- Required (validated by scripts/validate-env.mjs and src/config/env.ts) ---

# Supabase project URL (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase publishable key (browser-safe)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Stripe secret key (server-only — never expose to the browser)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# --- Optional / not yet consumed by code ---

SITE_URL=http://localhost:3000

# Supabase OAuth (server-only)
OAUTH_SUPABASE_CLIENT_ID=
OAUTH_SUPABASE_CLIENT_SECRET=
# Supabase CLI access token (server-only)
SUPABASE_ACCESS_TOKEN=

# Stripe publishable key. NOTE: name is misspelled and lacks the NEXT_PUBLIC_
# prefix, so it is NOT browser-exposed. Rename to NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# before using Stripe.js on the client.
STRIPE_PUBLISHBEL_KEY=pk_test_your_publishable_key
